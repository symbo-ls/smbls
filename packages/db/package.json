{
  "name": "@symbo.ls/db",
  "version": "3.6.4",
  "license": "MIT",
  "type": "module",
  "module": "./index.js",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    },
    "./supabase": {
      "import": "./adapters/supabase.js",
      "require": "./adapters/supabase.js"
    },
    "./rest": {
      "import": "./adapters/rest.js",
      "require": "./adapters/rest.js"
    },
    "./local": {
      "import": "./adapters/local.js",
      "require": "./adapters/local.js"
    }
  },
  "source": "index.js",
  "files": [
    "*.js",
    "adapters"
  ],
  "scripts": {
    "copy:package:cjs": "cp ../../build/package-cjs.json dist/cjs/package.json",
    "build:esm": "cross-env NODE_ENV=$NODE_ENV esbuild *.js adapters/*.js --target=es2020 --format=esm --outdir=dist/esm --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build:cjs": "cross-env NODE_ENV=$NODE_ENV esbuild *.js adapters/*.js --target=node18 --format=cjs --outdir=dist/cjs --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build:iife": "cross-env NODE_ENV=$NODE_ENV esbuild index.js --bundle --target=es2020 --format=iife --global-name=SmblsDb --outfile=dist/iife/index.js --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build": "node ../../build/build.js",
    "prepublish": "npm run build && npm run copy:package:cjs"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}

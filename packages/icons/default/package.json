{
  "name": "@symbo.ls/default-icons",
  "version": "3.6.0",
  "main": "./index.js",
  "author": "symbo.ls",
  "license": "ISC",
  "gitHead": "9fc1b79b41cdc725ca6b24aec64920a599634681",
  "files": [
    "dist",
    "*.js"
  ],
  "repository": "https://github.com/symbo-ls/smbls",
  "type": "module",
  "module": "./index.js",
  "unpkg": "./dist/iife/index.js",
  "jsdelivr": "./dist/iife/index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    },
    "./*.js": {
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "source": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "copy:package:cjs": "cp ../../../build/package-cjs.json dist/cjs/package.json",
    "build:esm": "cross-env NODE_ENV=$NODE_ENV esbuild *.js --target=es2020 --format=esm --outdir=dist/esm --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build:cjs": "cross-env NODE_ENV=$NODE_ENV esbuild *.js --target=node18 --format=cjs --outdir=dist/cjs --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build": "node ../../../build/build.js",
    "prepublish": "npm run build && npm run copy:package:cjs",
    "build:iife": "cross-env NODE_ENV=$NODE_ENV esbuild index.js --bundle --target=es2020 --format=iife --global-name=SmblsDefaultIcons --outfile=dist/iife/index.js --define:process.env.NODE_ENV=process.env.NODE_ENV"
  },
  "browser": "./dist/esm/index.js",
  "sideEffects": false
}

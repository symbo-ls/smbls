{
  "name": "@domql/funcql",
  "version": "3.7.4",
  "description": "Declarative function representation as JSON — serialize, interpret, and reverse functions as data",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "module": "./dist/esm/index.js",
  "unpkg": "./dist/iife/index.js",
  "jsdelivr": "./dist/iife/index.js",
  "main": "./dist/cjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "source": "index.js",
  "files": [
    "dist",
    "*.js"
  ],
  "scripts": {
    "copy:package:cjs": "cp ../../build/package-cjs.json dist/cjs/package.json",
    "build:esm": "cross-env NODE_ENV=$NODE_ENV esbuild *.js --target=es2020 --format=esm --outdir=dist/esm --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build:cjs": "cross-env NODE_ENV=$NODE_ENV esbuild *.js --target=node18 --format=cjs --outdir=dist/cjs --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build:iife": "cross-env NODE_ENV=$NODE_ENV esbuild index.js --bundle --target=es2020 --format=iife --global-name=DomqlFuncql --outfile=dist/iife/index.js --define:process.env.NODE_ENV=process.env.NODE_ENV",
    "build": "node ../../build/build.js",
    "prepublish": "npm run build && npm run copy:package:cjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0"
  },
  "browser": "./dist/esm/index.js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}

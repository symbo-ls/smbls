# Supabase — auto-filled by deploy.js if SUPABASE_ACCESS_TOKEN is set
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase personal access token (to create project + run migrations automatically)
# Get it at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Cloudflare (for wrangler pages deploy)
# Get API token at: https://dash.cloudflare.com/profile/api-tokens (use "Edit Cloudflare Workers" template)
# Get account ID at: https://dash.cloudflare.com/ (right sidebar)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

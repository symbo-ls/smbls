{
  "name": "smbls-root",
  "private": true,
  "scripts": {
    "start": "npm run clean:dist; parcel examples/index.html --no-cache --port 4321",
    "build": "npm run clean:dist; parcel build examples/index.html --no-cache",
    "build:packages": "npm run build --if-present --workspaces --include-workspace-root=false",
    "build:watch": "nodemon --exec \"npm run build:packages\" --ignore 'dist/*'",
    "prepare": "echo 'Run npm run build:packages to build all packages'",
    "update-linkable-list": "npx smbls link-packages -c",
    "test:lint": "npx standard \"packages/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "npm run clean:dist; npm run clean:packages; npm run clean:modules",
    "clean:dist": "rm -rf ./dist ./.cache ./.parcel-cache",
    "clean:modules": "rm -rf node_modules yarn.lock package-lock.json lerna-debug.log yarn-error.log",
    "clean:packages": "find . -path ./node_modules -prune -o -name dist -type d -print -exec rm -rf {} +",
    "reinstall": "npm run clean; npm i --verbose",
    "link:all": "npm run unlink --workspaces --if-present; npm run link --workspaces --if-present",
    "link:all-force": "npm run unlink --workspaces --if-present; npm run link:all"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/eslint-parser": "^7.27.1",
    "@babel/preset-env": "^7.27.1",
    "@parcel/babel-preset-env": "^2.11.0",
    "@parcel/transformer-raw": "^2.15.2",
    "babel-jest": "^29.7.0",
    "caniuse-lite": "^1.0.30001707",
    "commander": "^13.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.26.0",
    "eslint": "^9.28.0",
    "globusa": "^1.1.4",
    "jest": "^29.7.0",
    "parcel": "^2.15.2",
    "process": "^0.11.10",
    "rimraf": "^5.0.1",
    "standard": "^17.1.2",
    "svgo": "^3.3.2"
  },
  "standard": {
    "parser": "@babel/eslint-parser",
    "ignore": [
      "**test**",
      "**copy**"
    ]
  },
  "workspaces": [
    "packages/*",
    "packages/*/*",
    "plugins/*",
    "extensions/*"
  ],
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "version": "3.2.3"
}

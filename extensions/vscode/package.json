{
  "name": "@symbo.ls/vscode",
  "displayName": "Symbols.app Connect",
  "description": "IntelliSense for Symbols.app / DOMQL syntax — properties, events, components, element methods, state and more",
  "version": "3.2.4",
  "publisher": "symbo-ls",
  "repository": {
    "type": "git",
    "url": "https://github.com/symbo-ls/smbls"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "domql",
    "smbls",
    "symbols",
    "intellisense",
    "autocomplete"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "symbolsApp.toggle",
        "title": "Toggle Symbols.app IntelliSense",
        "category": "Symbols.app"
      },
      {
        "command": "symbolsApp.diagnose",
        "title": "Diagnose Symbols.app IntelliSense",
        "category": "Symbols.app"
      }
    ],
    "configuration": {
      "title": "Symbols.app",
      "properties": {
        "symbolsApp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Symbols.app IntelliSense"
        },
        "symbolsApp.detectByImports": {
          "type": "boolean",
          "default": true,
          "description": "Activate only in files importing from domql/smbls packages. When false, activates in all JS/TS files."
        },
        "symbolsApp.completeCssProps": {
          "type": "boolean",
          "default": true,
          "description": "Suggest CSS properties as top-level element keys (they get promoted to props automatically)"
        }
      }
    },
    "configurationDefaults": {
      "[javascript]": {
        "editor.quickSuggestions": { "strings": "on" }
      },
      "[typescript]": {
        "editor.quickSuggestions": { "strings": "on" }
      },
      "[javascriptreact]": {
        "editor.quickSuggestions": { "strings": "on" }
      },
      "[typescriptreact]": {
        "editor.quickSuggestions": { "strings": "on" }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "npm run esbuild-base",
    "watch": "npm run esbuild-base -- --watch",
    "package": "vsce package",
    "install-vsce": "npm install -g @vscode/vsce"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}

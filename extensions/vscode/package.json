{
  "name": "symbols-app-connect",
  "private": true,
  "displayName": "Symbols.app Connect",
  "description": "Symbols.app Connect for DOMQL syntax — properties, events, components, element methods, AI chat, and MCP integration",
  "version": "3.5.1",
  "publisher": "symbo-ls",
  "repository": {
    "type": "git",
    "url": "https://github.com/symbo-ls/smbls"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Chat"
  ],
  "keywords": [
    "domql",
    "smbls",
    "symbols",
    "intellisense",
    "autocomplete",
    "ai",
    "chat",
    "mcp"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onView:symbolsChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "symbolsApp.toggle",
        "title": "Toggle Symbols.app Connect",
        "category": "Symbols.app"
      },
      {
        "command": "symbolsApp.diagnose",
        "title": "Diagnose Symbols.app Connect",
        "category": "Symbols.app"
      },
      {
        "command": "symbolsApp.openChat",
        "title": "Open AI Chat",
        "category": "Symbols.app",
        "icon": "$(comment-discussion)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "symbols-ai",
          "title": "Symbols AI",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "symbols-ai": [
        {
          "type": "webview",
          "id": "symbolsChat",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "symbolsApp.openChat",
          "when": "view == symbolsChat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Symbols.app",
      "properties": {
        "symbolsApp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Symbols.app Connect"
        },
        "symbolsApp.detectByImports": {
          "type": "boolean",
          "default": true,
          "description": "Activate only in files importing from domql/smbls packages. When false, activates in all JS/TS files."
        },
        "symbolsApp.completeCssProps": {
          "type": "boolean",
          "default": true,
          "description": "Suggest CSS properties as top-level element keys (they get promoted to props automatically)"
        }
      }
    },
    "configurationDefaults": {
      "[javascript]": {
        "editor.quickSuggestions": {
          "strings": "on"
        }
      },
      "[typescript]": {
        "editor.quickSuggestions": {
          "strings": "on"
        }
      },
      "[javascriptreact]": {
        "editor.quickSuggestions": {
          "strings": "on"
        }
      },
      "[typescriptreact]": {
        "editor.quickSuggestions": {
          "strings": "on"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify && npm run copy-html",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "copy-html": "cp src/chat/webview.html out/webview.html",
    "compile": "npm run esbuild-base && npm run copy-html",
    "watch": "npm run esbuild-base -- --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "install-vsce": "npm install -g @vscode/vsce"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
